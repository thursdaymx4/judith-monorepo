{
  "expo": {
    "name": "Judith",
    "slug": "judith",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "judith",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0a0b0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.app.judith",
      "usesAppleSignIn": true,
      "appleTeamId": "88JK8X8BT7",
      "entitlements": {
        "com.apple.developer.icloud-container-identifiers": [
          "iCloud.com.app.judith",
          "iCloud.com.app.judith"
        ],
        "com.apple.developer.ubiquity-container-identifiers": [
          "iCloud.com.app.judith",
          "iCloud.com.app.judith"
        ],
        "com.apple.security.application-groups": [
          "group.com.app.judith",
          "group.com.app.judith"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.app.judith",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/a0a9f1ab-a9bb-4397-85ee-75138eec8109"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-updates",
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-audio",
        {
          "microphonePermission": "Pinapayagan ang Judith na gamitin ang mikropono para marinig ang mga tanong mo."
        }
      ],
      "expo-notifications",
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "a0a9f1ab-a9bb-4397-85ee-75138eec8109",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.app.judith.widget",
                  "targetName": "JudithWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.app.judith"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.app.judith.watchkitapp",
                  "targetName": "JudithWatch",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.app.judith"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
